{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "scripts": {
    "build": "turbo run build --filter=!docs",
    "build:fast": "turbo run build:fast --filter=!./packages/kits/** --filter=!negative-space --filter=!docs",
    "clean:pkgs": "turbo run clean --concurrency=8",
    "clean:node-modules": "pnpm tsx tools/clean-node-modules.ts",
    "create:pkg": "plop && pnpm install",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "lefthook install",
    "prettier": "prettier --write .",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.1",
    "@storybook/react": "^10.2.19",
    "@storybook/test": "^8.6.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "clean-package": "^2.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lefthook": "^2.1.4",
    "plop": "^4.0.4",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "19.2.3",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "turbo": "^2.6.3",
    "typescript-eslint": "^8.49.0"
  }
}
