{
  "name": "negative-space",
  "version": "2.7.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "Negative Space core, providing flexible building blocks for custom and accessible UI development",
  "keywords": [
    "components",
    "design-system",
    "react",
    "negative-space",
    "nsui",
    "ui"
  ],
  "license": "MIT",
  "main": "src/index.ts",
  "module": "",
  "types": "",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./action": "./src/action/index.ts",
    "./app": "./src/app/index.ts",
    "./data-display": "./src/data-display/index.ts",
    "./data-entry": "./src/data-entry/index.ts",
    "./feedback": "./src/feedback/index.ts",
    "./layout": "./src/layout/index.ts",
    "./navigation": "./src/navigation/index.ts",
    "./primitive": "./src/primitive/index.ts",
    "./typography": "./src/typography/index.ts"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/negative-space-ui/nsui.git.git",
    "directory": "packages/ui/button"
  },
  "bugs": {
    "url": "https://github.com/negative-space-ui/nsui/issues"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist .turbo dist",
    "postpack": "clean-package restore",
    "prepack": "pnpm tsx tools/replace-workspace-versions.ts && clean-package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@negative-space/action": "1.0.16",
    "@negative-space/app": "1.0.2",
    "@negative-space/data-display": "1.3.0",
    "@negative-space/data-entry": "1.5.0",
    "@negative-space/feedback": "1.4.0",
    "@negative-space/layout": "1.4.0",
    "@negative-space/navigation": "1.0.2",
    "@negative-space/primitive": "2.0.5",
    "@negative-space/provider": "1.10.1",
    "@negative-space/typography": "2.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
